  "rules": [
    {
      "match": {
        "type": "Exchange"
      },
      "set": {
        "classification": "exchange",
        "includeInTrackedSpend": false,
        "category": "internal-movement",
        "group": "Excluded",
        "normalizedMerchant": "Currency exchange",
        "notes": "Currency conversions are funding movements, not trip purchases."
      }
    },
    {
      "match": {
        "type": "Transfer"
      },
      "set": {
        "classification": "transfer",
        "includeInTrackedSpend": false,
        "category": "internal-movement",
        "group": "Excluded",
        "normalizedMerchant": "Account transfer",
        "notes": "Transfers between savings/current accounts or between people are excluded from spend."
      }
    },
    {
      "match": {
        "type": "ATM"
      },
      "set": {
        "classification": "cash-withdrawal",
        "includeInTrackedSpend": true,
        "category": "physical-cash",
        "group": "Physical Cash",
        "normalizedMerchant": "ATM cash withdrawal",
        "review": false,
        "notes": "Physical cash used during the trip across several purposes. Counted in total trip spend, but not broken down further."
      }
    },
    {
      "match": {
        "descriptionContains": "Suica Mobile Payment"
      },
